# Loki Configuration
LOKI_VERSION=3.0.0
LOKI_RETENTION_HOURS=168  # 7 days

# Promtail Configuration
PROMTAIL_VERSION=3.0.0

# Grafana Configuration
GRAFANA_VERSION=12.3.1
GF_SECURITY_ADMIN_PASSWORD=admin  # Change in production!
GF_AUTH_ANONYMOUS_ENABLED=false

# Application
APP_IMAGE=app-python:latest
APP_PORT=8000

# Resource Limits (optional, set to 0 to disable)
LOKI_MEMORY_LIMIT=1G
LOKI_MEMORY_RESERVATION=512M
LOKI_CPU_LIMIT=1.0
LOKI_CPU_RESERVATION=0.5

PROMTAIL_MEMORY_LIMIT=256M
PROMTAIL_MEMORY_RESERVATION=128M
PROMTAIL_CPU_LIMIT=0.5
PROMTAIL_CPU_RESERVATION=0.25

GRAFANA_MEMORY_LIMIT=512M
GRAFANA_MEMORY_RESERVATION=256M
GRAFANA_CPU_LIMIT=1.0
GRAFANA_CPU_RESERVATION=0.5

APP_MEMORY_LIMIT=256M
APP_MEMORY_RESERVATION=128M
APP_CPU_LIMIT=0.5
APP_CPU_RESERVATION=0.25

